QTA_MYSQL_ROOT_PASSWORD=qta_root_password
QTA_MYSQL_DATABASE=quant_trading_assistant
QTA_MYSQL_USER=qta
QTA_MYSQL_PASSWORD=qta_dev_password

# LongPort read-only quote provider. Keep disabled until SDK jar/native libs are available.
QTA_LONGPORT_ENABLED=false
QTA_LONGPORT_TIMEOUT_SECONDS=10
QTA_LONGPORT_QUOTE_TIME_ZONE=Asia/Shanghai
LONGPORT_APP_KEY=
LONGPORT_APP_SECRET=
LONGPORT_ACCESS_TOKEN=
LONGPORT_HTTP_URL=
LONGPORT_QUOTE_WEBSOCKET_URL=

# 行情执行引擎：调度器默认开启；FAKE provider 仅用于可重复的本地/验收测试。
QTA_MARKET_DATA_SCHEDULER_ENABLED=true
QTA_MARKET_DATA_SCHEDULER_SCAN_DELAY_MS=30000
QTA_MARKET_DATA_SCHEDULER_INITIAL_DELAY_MS=5000
QTA_MARKET_DATA_FAKE_ENABLED=false
QTA_MARKET_DATA_FAKE_FAILURE_SYMBOL=
